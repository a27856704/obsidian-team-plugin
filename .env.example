# ========================================
# 插件构建配置 (Plugin Build Configuration)
# 复制此文件为 .env 并修改对应的值
# 这些值会在构建时注入为默认设置
# ========================================

# 后端服务器地址
SERVER_URL=http://localhost:3000
WS_URL=ws://localhost:3000/ws/collab

# 默认 AI 提供商 (openai / claude / dmxapi / custom)
AI_PROVIDER=dmxapi

# 默认 AI API 端点
AI_ENDPOINT=https://www.dmxapi.cn/v1/chat/completions

# 默认 AI 模型
AI_MODEL=gpt-4
