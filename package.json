{
    "name": "obsidian-team-plugin",
    "version": "1.0.0",
    "description": "Obsidian Team Collaboration Plugin",
    "main": "main.js",
    "scripts": {
        "dev": "node esbuild.config.mjs",
        "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
        "version": "node version-bump.mjs && git add manifest.json versions.json"
    },
    "keywords": [
        "obsidian",
        "plugin",
        "team",
        "collaboration",
        "ai"
    ],
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^20.10.0",
        "esbuild": "^0.19.0",
        "obsidian": "latest",
        "tslib": "^2.6.0",
        "typescript": "^5.3.0"
    },
    "dependencies": {
        "@codemirror/state": "^6.4.1",
        "@codemirror/view": "^6.26.3",
        "y-codemirror.next": "^0.3.5",
        "y-websocket": "^3.0.0",
        "yjs": "^13.6.29"
    }
}
